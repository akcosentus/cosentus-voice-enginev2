# Per-environment CDK configuration. Copy to `.env.staging` or `.env.prod`
# and populate. These files are .gitignored — secrets and account-specific
# values do not live in version control.
#
# Values are also overridable via CDK context (`-c key=value`) at synth /
# deploy time; context wins over env vars per src/config.ts.
#
# Container image tag — used by ComputeStack to reference the ECR image.
# Defaults to 'latest' if unset. CI/CD overrides with a git sha at deploy
# time via `-c imageTag=$(git rev-parse --short HEAD)`.
IMAGE_TAG=latest

# AWS account + region (region pinned to us-east-1; cross-region not in scope)
CDK_DEFAULT_ACCOUNT=825269749545
CDK_DEFAULT_REGION=us-east-1

# Deployment environment — one of: staging | prod
ENVIRONMENT=staging

# DNS / TLS
#   DOMAIN_APEX           — the registered apex managed at GoDaddy
#   SERVICE_HOSTNAME      — the per-env hostname pointing at the ALB
#                           (prod: api.cosentusaibackend.com,
#                            staging: staging.cosentusaibackend.com)
#   CERTIFICATE_ARN       — ARN of the wildcard cert (shared across envs,
#                           lives in CertStack). Leave blank until CertStack
#                           is deployed.
DOMAIN_APEX=cosentusaibackend.com
SERVICE_HOSTNAME=staging.cosentusaibackend.com
CERTIFICATE_ARN=

# Auto-scaling sizing (validated by Layer 9.5 — see docs/scale-test-report)
#   MIN_CAPACITY               — staging: 1, prod: 1 (validate-then-commit;
#                                raised after Wave 6 mock load tests)
#   MAX_CAPACITY               — staging: 5, prod: 25
#   TARGET_SESSIONS_PCT        — 70 means scale out at 70% of
#                                max_concurrent_calls (= 4.2 sessions/task)
#   SCALE_OUT_COOLDOWN_SECONDS — 60 (fast ramp under burst)
#   SCALE_IN_COOLDOWN_SECONDS  — 300 (slow drain, prevents yo-yo)
MIN_CAPACITY=1
MAX_CAPACITY=5
TARGET_SESSIONS_PCT=70
SCALE_OUT_COOLDOWN_SECONDS=60
SCALE_IN_COOLDOWN_SECONDS=300

# Per-task session capacity (matches MAX_CONCURRENT_CALLS in the engine)
SESSION_CAPACITY_PER_TASK=6

# NAT gateway count — staging: 1 (cost saving), prod: 3 (full AZ HA)
NAT_GATEWAYS=1

# S3 recordings bucket
#   prod:    medcloud-voice-us-prod-825 (existing v1 bucket, imported)
#   staging: cosentus-voice-recordings-staging (CDK creates)
RECORDINGS_BUCKET_NAME=cosentus-voice-recordings-staging
RECORDINGS_BUCKET_OWNED_BY_CDK=true

# KMS key ARN protecting the recordings bucket.
#   Staging: leave empty — CDK creates the key and publishes the ARN to SSM
#            at synth time (alias/cosentus-voice-engine-staging-recordings).
#   Prod:    REQUIRED before deploy — set to the existing v1 KMS key ARN
#            that encrypts medcloud-voice-us-prod-825. Look it up via:
#              aws s3api get-bucket-encryption \
#                --bucket medcloud-voice-us-prod-825 \
#                --query 'ServerSideEncryptionConfiguration.Rules[0].ApplyServerSideEncryptionByDefault.KMSMasterKeyID'
RECORDINGS_KMS_KEY_ARN=
